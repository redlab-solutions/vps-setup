FROM caddy:builder AS builder

# Clone and patch caddy-dns/cloudflare to support cfat_-prefixed tokens (53 chars)
# The upstream regex {35,50} rejects newer Cloudflare API tokens that are 53 chars.
RUN git clone https://github.com/caddy-dns/cloudflare /tmp/cdf && \
    sed -i 's/{35,50}/{35,60}/' /tmp/cdf/cloudflare.go

RUN xcaddy build \
    --with github.com/caddy-dns/cloudflare=/tmp/cdf

FROM caddy:latest
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
